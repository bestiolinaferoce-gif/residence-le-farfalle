# Residence Le Farfalle — variabili ambiente
# Copia in .env.local e compila i valori

# URL base del sito (produzione) — canonical, Open Graph, hreflang, sitemap, robots
NEXT_PUBLIC_SITE_URL=https://www.residencelefarfalle.com

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console verification
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Form di contatto (Resend)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="Residence Le Farfalle <onboarding@resend.dev>"
# HOST_EMAIL=

# Partita IVA / Codice fiscale (opzionale)
# NEXT_PUBLIC_VAT_OR_CF=

# BOOKING_API (futuro)
# BOOKING_API_URL=
# BOOKING_API_KEY=
