# Residence Le Farfalle - Variabili ambiente
# Copia in .env.local e compila i valori

# URL base del sito (produzione) — canonical, Open Graph, hreflang
NEXT_PUBLIC_SITE_URL=https://www.residencelefarfalle.com

# Google Analytics 4 — sostituire con il Measurement ID reale da analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Email form (Resend)
# RESEND_API_KEY=
# HOST_EMAIL=

# API Booking (futuro)
# BOOKING_API_URL=
# BOOKING_API_KEY=

# Partita IVA / Codice fiscale titolare (opzionale — compare nel footer)
# NEXT_PUBLIC_VAT_OR_CF=
